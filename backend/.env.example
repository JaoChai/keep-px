# Server
PORT=8080
ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Facebook
FB_GRAPH_API_URL=https://graph.facebook.com/v21.0

# Google OAuth
GOOGLE_CLIENT_ID=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_RPS=100

# Public base URL
BASE_URL=https://pixlinks.xyz

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_REPLAY_1=price_xxx
STRIPE_PRICE_REPLAY_3=price_xxx
STRIPE_PRICE_REPLAY_UNLIMITED=price_xxx
STRIPE_PRICE_RETENTION_180=price_xxx
STRIPE_PRICE_RETENTION_365=price_xxx
STRIPE_PRICE_EVENTS_1M=price_xxx
STRIPE_PRICE_SALE_PAGES_25=price_xxx
STRIPE_PRICE_PIXELS_40=price_xxx

# Frontend URL (for Stripe redirect after checkout)
FRONTEND_URL=http://localhost:5173
