# Server
PORT=8080
ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Facebook
FB_GRAPH_API_URL=https://graph.facebook.com/v21.0

# Google OAuth
GOOGLE_CLIENT_ID=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_RPS=100

# Per-API-key rate limit for /events/ingest (requests per second / burst)
RATE_LIMIT_API_KEY_RPS=100
RATE_LIMIT_API_KEY_BURST=200

# Public base URL
BASE_URL=https://pixlinks.xyz

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_PIXEL_SLOT=price_xxx
STRIPE_PRICE_REPLAY_SINGLE=price_xxx
STRIPE_PRICE_REPLAY_MONTHLY=price_xxx

# Frontend URL (for Stripe redirect after checkout)
FRONTEND_URL=http://localhost:5173

# Sale Page Cache
SALE_PAGE_CACHE_TTL=60s

# S3/R2 Storage (for image uploads)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Token Encryption (32-byte hex key, required in production)
TOKEN_ENCRYPTION_KEY=

# Database Pool Tuning (defaults optimized for Neon serverless)
DB_MAX_CONNS=20
DB_MIN_CONNS=3
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=15s
DB_CONNECT_TIMEOUT=5s
DB_QUERY_TIMEOUT=10s
