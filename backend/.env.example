# Server
PORT=8080
ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Facebook
FB_GRAPH_API_URL=https://graph.facebook.com/v21.0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_RPS=100

# Public base URL
BASE_URL=https://pixlinks.xyz

# Cloudflare (for custom domains)
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_KV_NAMESPACE_ID=
CF_CNAME_TARGET=customer.pixlinks.xyz
